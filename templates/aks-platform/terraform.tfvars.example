prefix                         = "demoaks"
environment                    = "dev"
location                       = "eastus"
vnet_address_space             = ["10.10.0.0/16"]
aks_subnet_prefixes            = ["10.10.1.0/24"]
acr_sku                        = "Standard"
enable_cluster_auto_scaling    = true
default_node_pool_vm_size      = "Standard_D4s_v5"
default_node_pool_min_count    = 2
default_node_pool_max_count    = 5
default_node_pool_node_count   = 2
storage_container_names        = ["artifacts", "backups"]
aks_admin_group_object_ids     = []
tags = {
  owner = "platform-team"
}
